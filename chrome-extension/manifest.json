{
  "manifest_version": 3,
  "name": "Darija Translator",
  "version": "1.0",
  "description": "Translate English to Moroccan Darija",
  "permissions": ["sidePanel", "contextMenus", "activeTab", "storage"],
  "host_permissions": ["http://localhost:9090/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Darija Translator"
  }
}